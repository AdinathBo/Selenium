package javapackage;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;

public class WebTable1 {

	public static void main(String[] args) throws Exception {
		
		WebDriver driver = new ChromeDriver();
		
		driver.get("https://money.rediff.com/gainers");
		Thread.sleep(2000);

		driver.manage().window().maximize();
		Thread.sleep(2000);
		
		int rows=driver.findElements(By.xpath("//table[@class='dataTable']/tbody/tr")).size();
		System.out.println("total numberof rows in table: "+rows);
		
		int columns=driver.findElements(By.xpath("//table[@class='dataTable']/tbody/td")).size();
		System.out.println("total number of columns in table: "+columns);
	}
}
